<?xml version="1.0" encoding="utf-8"?>
<!--
    Default layout for the PermissionDialog.
    All visual properties (colors, text sizes) are applied programmatically
    from DialogConfig so developers can customise without forking layouts.
    Color resources are prefixed "permlib_" to avoid host-app conflicts.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/permission_dialog_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:minWidth="280dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_permission_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/permlib_title_permission_required"
        android:textStyle="bold"
        android:textSize="18sp"
        android:textColor="@color/permlib_text_primary"
        android:layout_marginBottom="12dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tv_permission_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/permlib_msg_permission_required"
        android:textSize="14sp"
        android:textColor="@color/permlib_text_secondary"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="24dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/permlib_divider"
        android:layout_marginBottom="8dp" />

    <!-- Button row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end">

        <!-- Cancel / Negative button -->
        <Button
            android:id="@+id/btn_permission_cancel"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permlib_btn_cancel"
            android:textColor="@color/permlib_btn_secondary"
            android:minWidth="80dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <!-- Open Settings / Positive button -->
        <Button
            android:id="@+id/btn_permission_settings"
            style="?attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/permlib_btn_open_settings"
            android:textColor="@color/permlib_btn_primary"
            android:textStyle="bold"
            android:minWidth="80dp"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

    </LinearLayout>

</LinearLayout>
